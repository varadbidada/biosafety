{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": "web",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "web/next-env.d.ts",
    "web/**/*.ts",
    "web/**/*.tsx",
    "web/.next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}